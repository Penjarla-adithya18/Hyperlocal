# =============================================================================
#  HyperLocal Jobs — Environment Variables Reference
#  Copy this file to .env.local and fill in your own values.
#  NEVER commit .env.local to version control.
#
#  KEY LEGEND
#  ----------
#  [LOCAL]          .env.local only — used during local development
#  [VERCEL]         Add in Vercel Dashboard → Project → Settings → Environment Variables
#  [SUPABASE]       Add via:  supabase secrets set KEY=value
#                   (used by Edge Functions running inside Supabase)
#  [VERCEL+SUPABASE] Must be set in BOTH places — Next.js API routes AND Edge Functions use it
#  [PUBLIC]         Safe to expose to the browser (NEXT_PUBLIC_ prefix)
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  SUPABASE
# ─────────────────────────────────────────────────────────────────────────────

# [PUBLIC] [VERCEL] — Supabase project URL (safe for browser)
# Found in: Supabase Dashboard → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# [PUBLIC] [VERCEL] — Anon (public) key — safe for browser, enforces RLS
# Found in: Supabase Dashboard → Settings → API → anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# [VERCEL] [SUPABASE] — Service Role key — bypasses RLS. NEVER expose client-side.
# Found in: Supabase Dashboard → Settings → API → service_role / secret
# Vercel: add to all environments (Production + Preview + Development)
# Supabase: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_SERVICE_ROLE_KEY=

# [PUBLIC] [VERCEL] — Enable Supabase backend (set to true in production)
NEXT_PUBLIC_USE_SUPABASE=true


# ─────────────────────────────────────────────────────────────────────────────
#  TWILIO — OTP (Verify) + SMS Notifications
#  Console: https://console.twilio.com
# ─────────────────────────────────────────────────────────────────────────────

# [VERCEL] [SUPABASE] — Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=

# [VERCEL] [SUPABASE] — Auth Token (keep secret)
TWILIO_AUTH_TOKEN=

# [VERCEL] [SUPABASE] — Sender phone number (E.164 format, e.g. +18382064197)
TWILIO_PHONE_NUMBER=

# [VERCEL] [SUPABASE] — Verify Service SID (starts with VA...) — used for OTP
# Create at: Twilio Console → Verify → Services
TWILIO_VERIFY_SERVICE_SID=

# [VERCEL] [SUPABASE] — Messaging Service SID (starts with MG...) — used for bulk SMS
# Create at: Twilio Console → Messaging → Services
# Optional: falls back to TWILIO_PHONE_NUMBER if not set
TWILIO_MESSAGING_SERVICE_SID=

# [VERCEL] — Default country code prepended to 10-digit numbers
OTP_DEFAULT_COUNTRY_CODE=+91


# ─────────────────────────────────────────────────────────────────────────────
#  AI — Gemini (Google)
#  Console: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────────────────

# [PUBLIC] [VERCEL] — Round-robin pool of Gemini API keys (comma-separated, no spaces)
# Multiple keys rotate automatically to stay within free-tier rate limits.
# Minimum 1 key required; more keys = higher throughput.
NEXT_PUBLIC_GEMINI_API_KEYS=


# ─────────────────────────────────────────────────────────────────────────────
#  AI — Groq (fast LLM inference)
#  Console: https://console.groq.com/keys
# ─────────────────────────────────────────────────────────────────────────────

# [VERCEL] — Round-robin pool of Groq API keys (comma-separated, no spaces)
# Keys can also be stored in Supabase app_config table for hot-rotation without redeploy.
GROQ_API_KEYS=

# [VERCEL] — Single Groq key (used by lib/whisper.ts for audio transcription)
GROQ_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  AI — Ollama (local/self-hosted LLM)
#  Docs: https://ollama.com
# ─────────────────────────────────────────────────────────────────────────────

# [LOCAL] — Ollama server URL (local dev only; not used in production)
OLLAMA_URL=http://localhost:11434

# [LOCAL] — Model to use (must be pulled with: ollama pull llama3.1:8b)
OLLAMA_MODEL=llama3.1:8b


# ─────────────────────────────────────────────────────────────────────────────
#  GOOGLE MAPS
#  Console: https://console.cloud.google.com → APIs & Services → Credentials
#  Enable: Maps JavaScript API, Geocoding API, Places API
# ─────────────────────────────────────────────────────────────────────────────

# [PUBLIC] [VERCEL] — Google Maps API key (restrict to your domain in production)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# [LOCAL] — Allow Maps to load on localhost during development
NEXT_PUBLIC_ENABLE_GOOGLE_MAPS_LOCALHOST=true

# [SUPABASE] — Server-side Maps key used inside Edge Functions
# supabase secrets set GOOGLE_MAPS_API_KEY=...
GOOGLE_MAPS_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  KYC — Sandbox.co.in (PAN / Aadhaar verification)
#  Dashboard: https://dashboard.sandbox.co.in
# ─────────────────────────────────────────────────────────────────────────────

# [VERCEL] — API key and secret from Sandbox dashboard
SANDBOX_API_KEY=
SANDBOX_API_SECRET=


# ─────────────────────────────────────────────────────────────────────────────
#  EMAIL — SMTP (Gmail recommended with App Password)
#  Used by: Supabase Edge Function  supabase/functions/email/index.ts
#  Set ALL four via:  supabase secrets set KEY=value
# ─────────────────────────────────────────────────────────────────────────────

# [SUPABASE] — SMTP server hostname
SMTP_HOST=smtp.gmail.com

# [SUPABASE] — SMTP port (587 for TLS / STARTTLS, 465 for SSL)
SMTP_PORT=587

# [SUPABASE] — SMTP login (your Gmail address)
SMTP_USER=you@gmail.com

# [SUPABASE] — Gmail App Password (NOT your account password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_PASS=

# [SUPABASE] — Display name used in From: header
EMAIL_FROM_NAME=HyperLocal Jobs


# ─────────────────────────────────────────────────────────────────────────────
#  WATI — WhatsApp Business API (optional)
#  Dashboard: https://app.wati.io → Settings → API
# ─────────────────────────────────────────────────────────────────────────────

# [VERCEL] — Bearer token from WATI dashboard
WATI_API_KEY=

# [PUBLIC] [VERCEL] — Base URL for your WATI account (include account ID)
NEXT_PUBLIC_WATI_BASE_URL=https://live-mt-server.wati.io/YOUR_ACCOUNT_ID


# ─────────────────────────────────────────────────────────────────────────────
#  FAST2SMS — Fallback SMS provider (India)
#  Dashboard: https://www.fast2sms.com/dashboard
# ─────────────────────────────────────────────────────────────────────────────

# [VERCEL] — API key from Fast2SMS dashboard
FAST2SMS_API_KEY=


# ─────────────────────────────────────────────────────────────────────────────
#  WEB PUSH — VAPID keys (Push Notifications)
#  Generate with:  npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────────────────────────────────

# [PUBLIC] [VERCEL] — VAPID public key (sent to browser for push subscription)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# [SUPABASE] — VAPID private key (Edge Function only — NEVER expose client-side)
# supabase secrets set VAPID_PRIVATE_KEY=...
VAPID_PRIVATE_KEY=

# [SUPABASE] — VAPID subject (mailto: or https: URL for contact)
VAPID_SUBJECT=mailto:admin@hyperlocal.app


# ─────────────────────────────────────────────────────────────────────────────
#  APP CONFIG
# ─────────────────────────────────────────────────────────────────────────────

# [PUBLIC] [VERCEL] — Canonical URL of your deployed app (no trailing slash)
# Used in email CTAs, OG tags, and internal redirects
NEXT_PUBLIC_APP_URL=https://yourdomain.vercel.app

# [PUBLIC] [VERCEL] — Alias used in some email templates
NEXT_PUBLIC_SITE_URL=https://yourdomain.vercel.app

# [SUPABASE] — Allowed CORS origin for Edge Functions
# supabase secrets set APP_ORIGIN=https://yourdomain.vercel.app
APP_ORIGIN=https://yourdomain.vercel.app


# ─────────────────────────────────────────────────────────────────────────────
#  CRON — Job-day SMS reminders  (/api/cron/job-day-reminders)
#  Scheduled at 6 AM daily via vercel.json  →  "schedule": "0 6 * * *"
# ─────────────────────────────────────────────────────────────────────────────

# [VERCEL] — Secret token; Vercel Cron passes it as  Authorization: Bearer <value>
# Use any strong random string, e.g.:  openssl rand -hex 32
CRON_SECRET=
